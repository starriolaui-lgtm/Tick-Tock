<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Tick-Tock to Top Marks | Daily Planner</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%- include('partials/alert') %>


  <div class="sidebar">
    <div class="mb-4">
      <h4 class="text-primary fw-bold mb-1">Tick-Tock to Top Marks</h4>
      <small class="text-muted">Your Learning Companion</small>
    </div>
    
    <nav class="nav flex-column">
      <a href="/student/dashboard" class="nav-link">
        <i class="bi bi-grid-fill me-3"></i>
        Dashboard
      </a>
      <a href="/student/daily-planner" class="nav-link">
        <i class="bi bi-calendar3 me-3"></i>
        Daily Planner
      </a>
      <a href="/student/study-tracker" class="nav-link">
        <i class="bi bi-graph-up me-3"></i>
        Study Tracker
      </a>
      <a href="/student/profile" class="nav-link">
        <i class="bi bi-person me-3"></i>
        Profile
      </a>
    </nav>
    
    <div class="user-profile">
      <div class="d-flex align-items-center">
        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
          <%= student.name.charAt(0).toUpperCase() %>
        </div>
        <div class="ms-3">
          <div class="fw-semibold"><%= student.name %></div>
          <small class="text-muted"><%= student.email %></small>
        </div>
      </div>
    </div>
    
    <div class="logout-btn">
      <a href="/auth/logout" class="nav-link">
        <i class="bi bi-box-arrow-right me-3"></i>
        Logout
      </a>
    </div>
  </div>


  <div class="main">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h3>Daily Planner</h3>
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addTaskModal">+ Add Task</button>
    </div>

    <% if (tasks.length === 0) { %>
      <p class="text-muted text-center">No tasks yet. Add your first one!</p>
    <% } else { %>
      <% tasks.forEach(task => { %>
        <div class="task-card">
          <div class="d-flex align-items-center gap-3">
            <form action="/student/update-status/<%= task.task_id %>" method="POST">
              <input type="hidden" name="status" value="<%= task.status === 'Done' ? 'Pending' : 'Done' %>">
              <input 
                type="checkbox" 
                onchange="this.previousElementSibling.value = this.checked ? 'Done' : 'Pending'; this.form.submit();" 
                <%= task.status === 'Done' ? 'checked' : '' %>>
            </form>
            <div>
              <h6 class="<%= task.status === 'Done' ? 'checked' : '' %> mb-1">
                <%= task.title %>
                <span class="priority <%= task.priority.toLowerCase() %>"><%= task.priority %></span>
              </h6>
              <small class="text-muted">
                From <%= new Date(task.start_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                - <%= new Date(task.end_time).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
              </small>
            </div>
          </div>
          <div class="task-actions">
            <button type="button" data-bs-toggle="modal" data-bs-target="#editTaskModal<%= task.task_id %>"><i class="bi bi-pencil-square"></i></button>
            <form action="/student/delete-task/<%= task.task_id %>" method="POST" style="display:inline;" onsubmit="return confirm('Delete this task session?');">
              <button type="submit"><i class="bi bi-trash"></i></button>
            </form>
          </div>
        </div>

      
        <div class="modal fade" id="editTaskModal<%= task.task_id %>" tabindex="-1">
          <div class="modal-dialog">
            <form action="/student/edit-task/<%= task.task_id %>" method="POST" class="modal-content">
              <div class="modal-header">
                <h5 class="modal-title">Edit Task</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
              </div>
              <div class="modal-body">
                <input type="text" name="title" class="form-control mb-3" value="<%= task.title %>" required>
                <textarea name="description" class="form-control mb-3"><%= task.description %></textarea>
                <input type="text" name="subject" class="form-control mb-3" value="<%= task.subject %>">

                <%
                const startDate = new Date(task.start_time);
                const localStart = new Date(startDate.getTime() - startDate.getTimezoneOffset() * 60000)
                         .toISOString()
                         .slice(0,16);
                %>
                <input type="datetime-local" name="start_time" class="form-control mb-3" value="<%= localStart %>">

                <%
                const endDate = new Date(task.end_time);
                const localEnd = new Date(endDate.getTime() - endDate.getTimezoneOffset() * 60000)
                         .toISOString()
                         .slice(0,16);
                %>

                <input type="datetime-local" name="end_time" class="form-control mb-3" value="<%= localEnd %>">
                <select name="priority" class="form-select mb-3">
                  <option <%= task.priority === 'Low' ? 'selected' : '' %>>Low</option>
                  <option <%= task.priority === 'Medium' ? 'selected' : '' %>>Medium</option>
                  <option <%= task.priority === 'High' ? 'selected' : '' %>>High</option>
                </select>
              </div>
              <div class="modal-footer">
                <button type="submit" class="btn btn-primary">Update Task</button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
              </div>
            </form>
          </div>
        </div>
      <% }) %>
    <% } %>
  </div>

 
  <div class="modal fade" id="addTaskModal" tabindex="-1">
    <div class="modal-dialog">
      <form action="/student/add-task" method="POST" class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Add New Task</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="text" name="title" class="form-control mb-3" placeholder="Title" required>
          <textarea name="description" class="form-control mb-3" placeholder="Description"></textarea>
          <input type="text" name="subject" class="form-control mb-3" placeholder="Subject">
          <input type="datetime-local" name="start_time" class="form-control mb-3" required>
          <input type="datetime-local" name="end_time" class="form-control mb-3" required>
          <select name="priority" class="form-select mb-3">
            <option selected disabled>Priority</option>
            <option>Low</option>
            <option>Medium</option>
            <option>High</option>
          </select>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary">Add Task</button>
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        </div>
      </form>
    </div>
  </div>


  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>