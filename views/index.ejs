<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tick-Tock to Top Marks</title>

  
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">


  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap" rel="stylesheet">

  <style>
    body {
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(to bottom right, #f8f9fa, #e2f0ff);
      height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .navbar {
      background-color: #ffffffcc;
      backdrop-filter: blur(8px);
    }

    .hero-section {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 40px;
    }

    .hero-section h1 {
      font-weight: 700;
      color: #004aad;
      font-size: 2.5rem;
      margin-bottom: 15px;
    }

    .hero-section p {
      color: #333;
      font-size: 1.1rem;
      margin-bottom: 25px;
    }

    .hero-section .btn-custom {
      background-color: #004aad;
      color: white;
      border-radius: 25px;
      padding: 10px 30px;
      margin: 5px;
      transition: background-color 0.3s ease;
      text-decoration: none;
    }

    .hero-section .btn-custom:hover {
      background-color: #002b6f;
    }

    footer {
      text-align: center;
      padding: 10px 0;
      font-size: 0.9rem;
      color: #555;
      background-color: #ffffff;
      box-shadow: 0 -2px 5px rgba(0, 0, 0, 0.05);
    }
  </style>
</head>

<body>
 
  <nav class="navbar navbar-expand-lg navbar-light py-3 fixed-top shadow-sm">
    <div class="container px-5">
      <a class="navbar-brand fw-bold text-primary" href="/">⏰ Tick-Tock to Top Marks</a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarSupportContent">
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="navbarSupportContent">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 fw-semibold">
          <li class="nav-item"><a class="nav-link" href="/auth/login">Login</a></li>
          <li class="nav-item"><a class="nav-link" href="/auth/register">Signup</a></li>
        </ul>
      </div>
    </div>
  </nav>

 
  <section class="hero-section">
    <h1>Welcome to Tick-Tock to Top Marks!</h1>
    <p>Manage your time wisely, stay productive, and reach your academic goals.</p>
    <div>
      <a href="/auth/login" class="btn btn-custom">Login</a>
      <a href="/auth/register" class="btn btn-custom">Get Started</a>
    </div>
  </section>


  <footer>
    <p>© 2025 Tick-Tock to Top Marks | Designed for Student Success</p>
  </footer>

 
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>