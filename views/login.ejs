<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tick-Tock to Top Marks | Time Management</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

  
  <% if (message) { %>
    <div class="alert alert-<%= message.type %> alert-dismissible fade show position-fixed top-0 start-50 translate-middle-x mt-3" 
         style="z-index: 2000; width: 90%; max-width: 500px;" 
         role="alert">
      <%= message.text %>
      <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
  <% } %>

  <div class="container d-flex align-items-center justify-content-center min-vh-100">
    <div class="card shadow-lg p-4" style="max-width: 450px; width: 100%;">
      
      <div class="text-center mb-4">
        <h1 class="text-primary fw-bold mb-2">Tick-Tock to Top Marks</h1>
        <p class="text-muted small">Time Management for Students</p>
      </div>

      <h2 class="text-center mb-4">Student Login</h2>

      <form action="/auth/login" method="POST">
        <div class="mb-3">
          <label for="email" class="form-label">Email Address</label>
          <input type="email" id="email" name="email" class="form-control" placeholder="Enter your email" required>
        </div>

        <div class="mb-3">
          <label for="password" class="form-label">Password</label>
          <input type="password" id="password" name="password" class="form-control" placeholder="Enter password" required>
        </div>

        <button type="submit" class="btn btn-primary w-100">Login</button>
      </form>

      <div class="text-center mt-3">
        <p class="mb-0">Create an account? <a href="/auth/register" class="text-decoration-none">Register here</a></p>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>