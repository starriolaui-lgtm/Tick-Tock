<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Tick-Tock to Top Marks | Study Tracker</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.0/font/bootstrap-icons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">

</head>
<body>

  <%- include('partials/alert') %>
  

  <div class="sidebar">
    <div class="mb-4">
      <h4 class="text-primary fw-bold mb-1">Tick-Tock to Top Marks</h4>
      <small class="text-muted">Your Learning Companion</small>
    </div>
    
    <nav class="nav flex-column">
      <a href="/student/dashboard" class="nav-link ">
        <i class="bi bi-grid-fill me-3"></i>
        Dashboard
      </a>
      <a href="/student/daily-planner" class="nav-link">
        <i class="bi bi-calendar3 me-3"></i>
        Daily Planner
      </a>
      <a href="/student/study-tracker" class="nav-link">
        <i class="bi bi-graph-up me-3"></i>
        Study Tracker
      </a>
      <a href="/student/profile" class="nav-link">
        <i class="bi bi-person me-3"></i>
        Profile
      </a>
    </nav>
    
    <div class="user-profile">
      <div class="d-flex align-items-center">
        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
          C
        </div>
        <div class="ms-3">
          <div class="fw-semibold"><%= student.name %></div>
          <small class="text-muted"><%= student.email %></small>
        </div>
      </div>
    </div>
    
    <div class="logout-btn">
      <a href="/auth/logout" class="nav-link">
        <i class="bi bi-box-arrow-right me-3"></i>
        Logout
      </a>
    </div>
  </div>


  
  <div class="main">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <div>
        <h2 class="mb-0">Study Tracker</h2>
        <p class="text-muted small">Log your study sessions and monitor your progress</p>
      </div>
      
      <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#logSessionModal">
        + Log Study Session
      </button>
    </div>

   
    <div class="card-outer">
      <% if (!sessions || sessions.length === 0) { %>
        <p class="text-center text-muted py-4">No study sessions logged yet. Click “Log Study Session” to add one.</p>
      <% } else { %>
        <% sessions.forEach(s => { 
           const mins = s.duration_minutes || 0;
           const hours = Math.floor(mins / 60);
           const minutes = mins % 60;
           let pretty = mins + 'm';
           if (hours > 0) pretty = hours + 'h ' + (minutes>0?minutes+'m':'');
        %>
          <div class="session-row d-flex justify-content-between align-items-center">
            <div class="d-flex gap-3 align-items-center">
              <div class="duration-badge"><%= pretty %></div>
              <div>
                <div class="fw-semibold"><%= s.subject || 'Untitled' %></div>
                <div class="text-muted small"><%= s.description ? s.description : '' %></div>
                <div class="text-muted small mt-1">
                  <% if (s.start_time) { %>
                    <%= new Date(s.start_time).toLocaleDateString([], { dateStyle: 'medium' }) %>
                  <% } else { %>
                    <%= new Date(s.date_created).toLocaleDateString([], { dateStyle: 'medium' }) %>
                  <% } %>
                </div>
              </div>
            </div>

            <div class="d-flex align-items-center gap-2">
              <form action="/student/delete-session/<%= s.study_id %>" method="POST" onsubmit="return confirm('Delete this study session?');">
                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
              </form>
            </div>
          </div>
        <% }) %>
      <% } %>
    </div>
  </div>

  
  <div class="modal fade" id="logSessionModal" tabindex="-1" aria-labelledby="logSessionModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow-lg">
        <div class="modal-header border-0">
          <h5 class="modal-title fw-semibold" id="logSessionModalLabel">Log Study Session</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form action="/student/log-session" method="POST">
          <div class="modal-body px-4 pb-4">
            <div class="mb-3">
              <label class="form-label fw-semibold">Subject</label>
              <input type="text" name="subject" class="form-control"  required>
            </div>

            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Duration (minutes)</label>
                <input type="number" name="duration_minutes" class="form-control" min="1" placeholder="60" required>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-semibold">Date</label>
                <input type="date" name="start_time" class="form-control" value="<%= new Date().toISOString().slice(0,10) %>" required>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-semibold">Notes (optional)</label>
              <textarea name="description" class="form-control" rows="3" placeholder="What did you learn or accomplish?"></textarea>
            </div>
          </div>

          <div class="modal-footer border-0">
            <button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-dark">Log Session</button>
          </div>
        </form>
      </div>
    </div>
  </div>



  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>